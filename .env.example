# ANTHROPIC_API_KEY: Required for Claude API calls (the regulatory advisor).
# Get one from https://console.anthropic.com and set it here for local dev,
# or as an environment variable in your Vercel project settings for production.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
